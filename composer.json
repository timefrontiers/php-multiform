{
  "name": "timefrontiers/php-multiform",
  "description": "Dynamic table entity class with runtime table resolution",
  "type": "library",
  "license": "MIT",
  "version": "1.0.0",
  "keywords": ["php", "database", "orm", "dynamic-table", "multi-table"],
  "authors": [
    {
      "name": "Time Frontiers",
      "email": "dev@timefrontiers.com",
      "homepage": "https://timefrontiers.com"
    }
  ],
  "require": {
    "php": ">=8.1",
    "timefrontiers/php-database-object": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "TimeFrontiers\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "TimeFrontiers\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true
  }
}
